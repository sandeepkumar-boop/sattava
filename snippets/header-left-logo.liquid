{%- if section.settings.menu != blank -%}
	{% render 'header-drawer' %}
{%- endif -%}

{% render 'header-logo', tag: 'h1' %}

<nav class='header__inline-menu'>
	{%- if section.settings.menu != blank -%}
		<ul class='list-menu list-menu--inline' role='list'>
			{%- for link in section.settings.menu.links -%}
				{% liquid
					assign mega_menu = false
					assign mega_menu_list = false
					assign mega_menu_blocks = false
					assign mega_menu_tabs = false
					assign mega_submenu = false
				%}
				{%- if link.links != blank -%}
					{% if section.blocks.size > 0 %}
						{% for block in section.blocks %}
							{% liquid
								assign mega_menu_trigger = block.settings.mega_menu_trigger | handle | strip
								assign mega_menu_list_trigger = block.settings.mega_menu_list_trigger | handle | strip
								assign mega_menu_blocks_trigger = block.settings.mega_menu_blocks_trigger | handle | strip
								assign mega_menu_tabs_trigger = block.settings.mega_menu_tabs_trigger | handle | strip
								assign tabs_color_scheme = 'background-1'

								if link.handle == mega_menu_trigger
									assign mega_menu = true
									assign mega_menu_list = false
									assign mega_menu_blocks = false
									assign mega_menu_tabs = false
									assign shopify_attributes = block.shopify_attributes
								elsif link.handle == mega_menu_list_trigger
									assign mega_menu_list = true
									assign mega_menu = false
									assign mega_menu_blocks = false
									assign mega_menu_tabs = false
									assign shopify_attributes = block.shopify_attributes
								elsif link.handle == mega_menu_blocks_trigger
									assign mega_menu_blocks = true
									assign mega_menu_list = false
									assign mega_menu = false
									assign mega_menu_tabs = false
									assign shopify_attributes = block.shopify_attributes
								elsif link.handle == mega_menu_tabs_trigger
									assign mega_menu_tabs = true
									assign mega_menu_blocks = false
									assign mega_menu_list = false
									assign mega_menu = false
									assign shopify_attributes = block.shopify_attributes
								endif

								if block.type == 'mega_menu_tabs'
									assign tabs_color_scheme = block.settings.color_scheme_tabs
								endif
							%}

							{% assign mega_submenu_trigger = block.settings.mega_submenu_trigger | handle | strip %}

							{% if link.handle == mega_submenu_trigger and block.type == 'mega_submenu' and link.links != blank %}
								{% assign mega_submenu = true %}
							{% endif %}
						{% endfor %}
					{% endif %}
					{% comment %} TODO: remove visibility class {% endcomment %}
					<li
						class='list-menu-item {% if mega_menu or mega_menu_blocks or mega_menu_list or mega_submenu %}list-menu--megamenu {% elsif mega_menu_tabs %}list-menu--megamenu list-menu--tabs{% else %}list-menu--submenu{% endif %} {% if mega_submenu %} list-menu--megasubmenu{% endif %}'
						{{ shopify_attributes }}>
						<a
							href='{{ link.url }}'
							class='header__menu-item list-menu__item link focus-inset {%- if link.active %} header__active-menu-item{% endif %}'
							{% if link.current %}
								aria-current='page'
							{% endif %}
							aria-label='{{ link.title | escape }}'>
							<span title='{{ link.title | escape }}'>
								{{ link.title | escape }}
							</span>
						</a>
						{% if mega_menu %}
							<div class='header__mega-menu mega-menu mega-menu--columns color-background-1'>
								<div class='mega-menu__inner container'>
									{% render 'mega-menu-columns', link: link, blocks: section.blocks %}
								</div>
							</div>
						{% elsif mega_menu_list %}
							<div class='header__mega-menu mega-menu mega-menu--list color-background-1'>
								<div class='mega-menu__inner container'>
									{% render 'mega-menu-list', link: link, blocks: section.blocks %}
								</div>
							</div>
						{% elsif mega_menu_blocks %}
							<div class='header__mega-menu mega-menu mega-menu--blocks color-background-1'>
								<div class='mega-menu__inner container'>
									{% render 'mega-menu-blocks', link: link, blocks: section.blocks %}
								</div>
							</div>
						{% elsif mega_menu_tabs %}
							<div class='header__mega-menu mega-menu mega-menu--tabs color-{{ tabs_color_scheme }}'>
								{% render 'mega-menu-tabs', link: link, blocks: section.blocks %}
							</div>
						{% elsif mega_submenu %}
								{% render 'header-mega-submenu', link: link, section: section %}
						{% else %}
							{% render 'submenu', link: link %}
						{% endif %}
					</li>
				{%- else -%}
					<li class='list-menu-item'>
						<a
							href='{{ link.url }}'
							class='header__menu-item list-menu__item link focus-inset {%- if link.active %} header__active-menu-item{% endif %}'
							{% if link.current %}
								aria-current='page'
							{% endif %}
							aria-label='{{ link.title | escape }}'>
							<span title='{{ link.title | escape }}'>
								{{ link.title | escape }}
							</span>
						</a>
					</li>
				{%- endif -%}
			{%- endfor -%}
		</ul>
	{%- endif -%}
</nav>

{% if section.settings.small_menu != blank %}
	<ul class='header__small-menu small-menu list-unstyled' role='list'>
		{%- for link in section.settings.small_menu.links limit: 3 -%}
			<li class='small-menu__item'>
				{%- if link != blank -%}
					<a
						href='{{ link.url }}'
						class='small-menu__link link link--text focus-inset caption-large {%- if link.active %} small-menu__link--active{% endif %}'
						{% if link.current %}
							aria-current='page'
						{% endif %}>
						<span>
							{{ link.title | escape }}
						</span>
					</a>
				{% endif %}
			</li>
		{% endfor %}
	</ul>
{% endif %}

<div class='header__column'>
	<div class='header__icons'>
		{%- if section.settings.show_social -%}
