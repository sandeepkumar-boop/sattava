ck_order":["carousel_slide_e4pNCY","carousel_slide_jfaeRK","carousel_slide_ePamBY","carousel_slide_iQG4pF"],"disabled":true,"name":"t:sections.carousel.name","settings":{"subheading":"","heading":"The women behind the work","heading_size":"h1","columns":4,"image_ratio":"square","button_show":true,"button_label":"Meet Them All","button_link":"","padding_top":"m","padding_bottom":"m"}},"image_with_text_LxWH8e":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","subheading":"","heading":"Our Process","heading_size":"h1","text":"<h6><br\/>● <strong>Sourcing<\/strong><br\/>   Carefully selecting reclaimed and surplus textiles.<\/h6><h6>● <strong>Design & Patterning<\/strong><br\/>Products are designed for everyday use functional, durable, timeless.<\/h6><h6>● <strong>Training & Skill Building<\/strong><br\/>Artisans are trained on product-specific techniques, quality standards, and finishing.<br\/><br\/><br\/>● <strong>Stitching & Assembly<\/strong><br\/>Made in small batches, by hand and machine, under fair working conditions.<\/h6><h6>● <strong>Quality Check<\/strong><br\/>Every piece is inspected before it reaches you.<\/h6>","show_button":false,"button_label":"Explore All","button_link":"","button_style":"primary","text_align":"center","text_width":"small","image":"shopify:\/\/shop_images\/1122265264baecd461c0ae7bb22388d6f7e980d0.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"all-height","position":"container","layout":"text_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"l","padding_bottom":"l"}},"product_markers_xxr8J7":{"type":"product-markers","blocks":{"product_markers_item_TTMrQw":{"type":"product_markers_item","settings":{"product_id":"","position_x":12,"position_y":14,"tooltip_open_position":"to-right"}}},"block_order":["product_markers_item_TTMrQw"],"name":"t:sections.product_markers.name","settings":{"subheading":"","heading":"Elements of Craft","heading_size":"h2","image":"shopify:\/\/shop_images\/Screenshot_2026-03-02_204118.png","aspect_ratio":"16\/9","image_ratio":"landscape","show_vendor":true,"margin_top":"m","margin_bottom":"m"}},"image_with_text_Vr7pEc":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","subheading":"","heading":"Sustainability, By Design","heading_size":"h1","text":"<h6><\/h6><h6><\/h6><h6><\/h6><h6>At Sattva, sustainability is not an add-on. It begins at the drawing board and carries through every decision we make.<br\/><br\/>We work with reclaimed and surplus textiles - fabrics that already exist in the world and reimagine them into objects meant for everyday use. By choosing what's already available, we reduce the need for new material production and give value to what might otherwise be overlooked.<br\/><br\/><\/h6>","show_button":false,"button_label":"Explore All","button_link":"","button_style":"primary","text_align":"top","text_width":"medium","image":"shopify:\/\/shop_images\/d653dbf1aa179e439b1e2280de21d1ac0ded8f91_1.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"small","position":"container","layout":"text_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"l","padding_bottom":"s"}},"image_with_text_a6GU6C":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","subheading":"","heading":"","heading_size":"h2","text":"<h6>Our products are made in small batches, allowing us to work thoughtfully rather than at scale for its own sake. This approach minimizes excess, encourages careful craftsmanship, and ensures that every piece receives the attention it deserves.<br\/><br\/>Equally important is how our products are made. We collaborate with women artisans from Mumbai's neighborhoods, focusing on skill-based work, fair compensation, and long-term continuity rather than one-off production. Sustainability, for us, is as much about people as it is about materials.<br\/><br\/><\/h6>","show_button":false,"button_label":"Explore All","button_link":"","button_style":"primary","text_align":"center","text_width":"medium","image":"shopify:\/\/shop_images\/a38eeda65747d8c076e4d38339f4d8bd9b066f40.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"small","position":"container","layout":"image_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"no-indent","padding_bottom":"xs"}},"image_with_text_a9eKwn":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","subheading":"","heading":"","heading_size":"h2","text":"<h6>We avoid seasonal trends and disposable design. Instead, we create functional, durable essentials - objects meant to be used, repaired, and lived with over time. When a product lasts longer, it leaves a lighter footprint.<br\/><br\/>Sattva's idea of sustainability is quiet and considered. It's not about perfection, but about responsibility making better choices, consistently, and with care.<br\/><br\/><\/h6>","show_button":false,"button_label":"Explore All","button_link":"","button_style":"primary","text_align":"center","text_width":"medium","image":"shopify:\/\/shop_images\/c1ffd284db0edf74260fccccdcc6ff7f5e359f80_2.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"small","position":"container","layout":"text_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"xs","padding_bottom":"xl"}},"featured_blog_afKbye":{"type":"featured-blog","disabled":true,"name":"t:sections.featured-blog.presets.name","settings":{"subheading":"","heading":"Featured posts","heading_size":"h2","post_layout":"column","blog":"news","post_limit":6,"post_limit_grid":4,"show_image":true,"show_tags":true,"show_date":true,"show_author":true,"show_excerpt":false,"show_view_all":true,"button_label":"Go to blogs","button_style":"simple","padding_top":"m","padding_bottom":"m"}},"multicolumn_BfpMy3":{"type":"multicolumn","blocks":{"column_wzzAaH":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/4f6a1351f762a0b62ac02f34a71a25c4e72ad592.png","icon":"none","heading":"Carry","text":"<p>Totes, laptop sleeves, pouches, bags<br\/><br\/><\/p>","show_button":true,"button_label":"View Category","button_link":"https:\/\/www.google.com","button_style":"primary","full_link":false,"additional_text_1":"","additional_text_2":""}},"column_c7UBey":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/063b4f59efd993c0e89b4fde1fde2df1ce8f60f4.png","icon":"bag","heading":"Keep","text":"<p>Wallets, cases, organizers, daily utility items<br\/><br\/><\/p>","show_button":true,"button_label":"View Category","button_link":"https:\/\/www.googlecom","button_style":"primary","full_link":false,"additional_text_1":"","additional_text_2":""}},"column_Dgbpjh":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/b58e00b4b64cd4133161210f878762540b9cf9e8.png","icon":"bell","heading":"Adorn"