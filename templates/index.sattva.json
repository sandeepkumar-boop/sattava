    "sattva_earth_story": {
      "type": "sattva-image-with-text",
      "settings": {
        "subheading": "New Collection",
        "heading": "Earth Story",
        "text": "<p>Inspired by the panchatattvas, discarded textiles are slowly joined, embellished, and embroidered into pieces of conscious beauty.</p>",
        "button_label": "Explore Collection",
        "layout": "text-left",
        "padding_top": "l",
        "padding_bottom": "l"
      }
    },
