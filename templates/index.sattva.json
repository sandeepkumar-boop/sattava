        "quote": "\"Made slowly. Made with intention. Made by hands that matter.\"",
        "products_to_show": 6,
        "image_ratio": "square",
        "padding_top": "l",
        "padding_bottom": "l"
      }
    },
    "sattva_gifting": {
      "type": "sattva-gifting-cta",
      "settings": {
        "heading": "Thoughtful gifts with story stitched in",
        "text": "<p>Sattva offers thoughtful corporate gifting - from curated hampers to customised pieces designed for teams, clients, and special occasions. Made in small batches and crafted from upcycled textiles by skilled women artisans, each gift carries purpose, meaning, and a story worth sharing.</p>",
        "button_label": "Explore Gifting",
        "padding_top": "l",
        "padding_bottom": "l"
      }
