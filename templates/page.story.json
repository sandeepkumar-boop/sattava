ext_2":""}}},"block_order":["column_UF9dTU","column_rkkprP","column_i8WcFA"],"disabled":true,"name":"t:sections.multicolumn.name","settings":{"section_type":"full_image","color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","multicolumn_to_show":3,"heading":"Collaborations and Training Events","heading_size":"h2","image_width":"medium","image_ratio":"square","object_fit":"cover","swipe_on_mobile":false,"card_heading_size":"h4","padding_top":"l","padding_bottom":"l"}},"image_banner_6f3ewE":{"type":"image-banner","disabled":true,"name":"t:sections.image-banner.presets.name","settings":{"full_width":true,"color_scheme":"background-4","image":"shopify:\/\/shop_images\/83cd29334a30c7aec2891f759e193b87493d84aa_1.png","image_ratio":"16\/9","image_ratio_mobile":"recommended","opacity_overlay":0.4,"subheading":"","heading":"Craft Cluster","heading_size":"h2","text_information":"<p>At Sattva, we work with women artisans organised into small clusters, each with its own strengths, skills, and specialisations.<br\/>Some clusters focus on specific techniques -such as patchwork, embroidery, or textile preparation - while others handle full product assembly and finishing. In many cases, clusters collaborate across stages of a product, coming together to create a single collection. Larger, more established clusters also work closely with Sattva to develop their own collections from start to finish. This distributed way of making allows us to honour skill, ensure quality, and create meaningful collaboration across communities. You can explore products by the clusters that shaped them within our collections.<br\/><br\/><\/p>","text_align":"bottom-left","text_width":"full","additional_text":"","show_view_all":false,"button_label":"Shop now","button_style":"secondary","button_link":"https:\/\/WWW.GOOGLE.COM","margin_top":"no-indent","margin_bottom":"s"}},"multicolumn_jE7FR9":{"type":"multicolumn","blocks":{"column_FRK6CC":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/4f6a1351f762a0b62ac02f34a71a25c4e72ad592.png","icon":"none","heading":"Products By Andheri Cluster","text":"","show_button":false,"button_label":"Know More","button_link":"https:\/\/www.google.com","button_style":"primary","full_link":true,"additional_text_1":"","additional_text_2":""}},"column_VW8eem":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/063b4f59efd993c0e89b4fde1fde2df1ce8f60f4.png","icon":"none","heading":"Products By Anand Nagar Cluster","text":"","show_button":false,"button_label":"Know More","button_link":"shopify:\/\/products\/jewelry-boxes","button_style":"primary","full_link":true,"additional_text_1":"","additional_text_2":""}},"column_NLDWPM":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/b58e00b4b64cd4133161210f878762540b9cf9e8.png","icon":"none","heading":"Products By Jail Cluster","text":"","show_button":false,"button_label":"Know More","button_link":"https:\/\/www.google","button_style":"primary","full_link":true,"additional_text_1":"","additional_text_2":""}}},"block_order":["column_FRK6CC","column_VW8eem","column_NLDWPM"],"disabled":true,"name":"t:sections.multicolumn.name","settings":{"section_type":"full_image","color_scheme":"background-1","multicolumn_to_show":3,"heading":"Products Made By our Clusters","heading_size":"h2","image_width":"medium","image_ratio":"portrait","object_fit":"cover","swipe_on_mobile":false,"card_heading_size":"h3","padding_top":"l","padding_bottom":"xl"}},"main":{"type":"main-page","disabled":true,"settings":{"padding_top":"no-indent","padding_bottom":"m"}},"image_with_text_UC9qYD":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","image_width":50,"subheading":"","heading":"Our Process","heading_size":"h1","text":"<h6><br\/>● <strong>Sourcing<\/strong><br\/>   Carefully selecting reclaimed and surplus textiles.<\/h6><h6>● <strong>Design & Patterning<\/strong><br\/>Products are designed for everyday use functional, durable, timeless.<\/h6><h6>● <strong>Training & Skill Building<\/strong><br\/>Artisans are trained on product-specific techniques, quality standards, and finishing.<br\/><br\/><br\/>● <strong>Stitching & Assembly<\/strong><br\/>Made in small batches, by hand and machine, under fair working conditions.<\/h6><h6>● <strong>Quality Check<\/strong><br\/>Every piece is inspected before it reaches you.<\/h6>","show_button":false,"button_label":"Explore All","button_link":"","button_style":"primary","text_align":"center","text_width":"small","image":"shopify:\/\/shop_images\/1122265264baecd461c0ae7bb22388d6f7e980d0.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"all-height","position":"container","layout":"text_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"l","padding_bottom":"l"}},"elements_of_craft_UYfiW6":{"type":"elements-of-craft","blocks":{"craft_dtiwYw":{"type":"craft","settings":{"top":20,"left":30,"image":"shopify:\/\/shop_images\/Catagory_4_ex2.jpg","title":"Ajrakh Prints","text":"Traditional block-printed textiles known for their deep hues and geometric rhythm. Often sourced from surplus or deadstock."}},"craft_bzDzRH":{"type":"craft","settings":{"top":20,"left":30,"image":"shopify:\/\/shop_images\/Catagory_1_ex1.png","title":"Patchwork","text":"Recovered textile fragments are carefully sorted, matched, and stitched into new compositions. No two pieces are ever the same."}},"craft_xX8pFF":{"type":"craft","settings":{"top":20,"left":30,"image":"shopify:\/\/shop_images\/Catagory_7_ex1.png","title":"Kantha Stitching","text":"The kantha stitch is a simple running stitch that serves both utilitarian and decorative purposes. In its most basic form, it holds multiple layers of fabric together."}},"craft_6BXB7N":{"type":"craft","settings":{"top":20,"left":30,"image":"shopify:\/\/shop_images\/Catagory5ex2.png","title":"Denim","text":"Discarded or excess denim reworked into durable, everyday essentials, built to age beautifully."}},"craft_MpJUc8":{"type":"craft","settings":{"top":20,"left":30,"image":"shopify:\/\/shop_images\/Catagory_7_ex2.png","title":"Hand Embroidery","text":"Small, deliberate details added by hand, giving each piece a quiet individuality."}}},"block_order":["craft_dtiwYw","craft_bzDzRH","craft_xX8pFF","craft_6BXB7N","craft_MpJUc8"],"name":"Elements of Craft","settings":{"heading":"Elements of Craft"}},"image_with_text_CpUF6w":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","image_width":50,"subheading":"","heading":"Sustainability, By Design","heading_size":"h1","text":"<h6><\/h6><h6><\/h6><h6><\/h6><h6>At Sattva, sustainability is not an add-on. It begins at the drawing board and carries through every decision we make.<br\/><br\/>We work with reclaimed and surplus textiles - fabrics that already exist in the world and reimagine them into objects meant for everyday use. By choosing what's already available, we reduce the need for new material production and give value to what might otherwise be overlooked.<br\/><br\/><\/h6>","show_button":false,"button_label":"Explore All","button_link":"","button_style":"primary","text_align":"top","text_width":"medium","image":"shopify:\/\/shop_images\/d653dbf1aa179e439b1e2280de21d1ac0ded8f91_1.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"small","position":"container","layout":"text_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"l","padding_bottom":"s"}},"image_with_text_7dybJY":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","image_width":50,"subheading":"","heading":"","heading_size":"h2","text":"<h6>Our products are made in small batches, allowing us to work thoughtfully rather than at scale for its own sake. This approach minimizes excess, encourages careful craftsmanship, and ensures that every piece receives the attention it deserves.<br\/><br\/>Equally important is how our products are made. We collaborate with women artisans from Mumbai's neighborhoods, focusing on skill-based work, fair compensation, and long-term continuity rather than one-off production. Sustainability, for us, is as much about people as it is about materials.<br\/><br\/><\/h6>","show_button":false,"button_label":"Explore All","button_link":"","button_style":"primary","text_align":"center","text_width":"medium","image":"shopify:\/\/shop_images\/a38eeda65747d8c076e4d38339f4d8bd9b066f40.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"small","position":"container","layout":"image_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"no-indent","padding_bottom":"xs"}},"image_with_text_F6kktd":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","image_width":50,"subheading":"","heading":"","heading_size":"h2","text":"<h6>We avoid seasonal trends and disposable design. Instead, we create functional, durable essentials - objects meant to be used, repaired, and lived with over time. When a product lasts longer, it leaves a lighter footprint.<br\/><br\/>Sattva's idea of sustainability is quiet and considered. It's not about perfection, but about responsibility making better choices, consistently, and with care.<br\/><br\/><\/h6>","show_button":false,"button_label":"Explore All","button_link":"","button_style":"primary","text_align":"center","text_width":"medium","image":"shopify:\/\/shop_images\/c1ffd284db0edf74260fccccdcc6ff7f5e359f80_2.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"small","position":"container","layout":"text_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"xs","padding_bottom":"xl"}},"multicolumn_gA3RHi":{"type":"multicolumn","blocks":{"column_JdQjhN":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/4f6a1351f762a0b62ac02f34a71a25c4e72ad592.png","icon":"none","heading":"Carry","text":"<p>Totes, laptop sleeves, pouches, bags<br\/><br\/><\/p>","show_button":false,"button_label":"View Category","button_link":"https:\/\/www.google.com","button_style":"primary","full_link":true,"additional_text_1":"","additional_text_2":""}},"column_6RfkRz":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/063b4f59efd993c0e89b4fde1fde2df1ce8f60f4.png","icon":"bag","heading":"Keep","text":"<p>Wallets, cases, organizers, daily utility items<br\/><br\/><\/p>","show_button":false,"button_label":"View Category","button_link":"https:\/\/www.googlecom","button_style":"primary","full_link":true,"additional_text_1":"","additional_text_2":""}},"column_TPxeA9":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/b58e00b4b64cd4133161210f878762540b9cf9e8.png","icon":"bell","heading":"Adorn","text":"<p>textile jewelry, small accessories, wearables<br\/><br\/><\/p>","show_button":false,"button_label":"View Category","button_link":"https:\/\/www.google.com","button_style":"primary","full