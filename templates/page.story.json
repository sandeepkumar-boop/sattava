{"sections":{"image_with_text_yhHHfx":{"type":"image-with-text","name":"t:sections.image-with-text.presets.name","settings":{"color_scheme":"scheme-0e65bf93-c3c9-4e32-a45d-d6c35586da83","image_width":50,"subheading":"","heading":"The Ground Story","heading_size":"h2","text":"<h6>Sattva was born from a simple belief: That everyday objects can carry dignity, intention, and human touch - without shouting for attention.<br\/>In a city like Mumbai, skill exists everywhere. What's missing is access, continuity, and fair opportunity. Sattva exists to bridge that gap through thoughtful design and honest making.<br\/><br\/><\/h6>","show_button":true,"button_label":"Explore gifting","button_link":"https:\/\/WWW.GOOGLE.COM","button_style":"primary","text_align":"center","text_width":"medium","image":"shopify:\/\/shop_images\/184f97202df3655444ba0b35f0410c046d7547b2.png","autoplay_video":true,"muted_video":true,"loop_video":true,"show_icon_play":false,"show_icon_sound":false,"autoplay_video_secondary":true,"muted_video_secondary":true,"loop_video_secondary":true,"show_icon_play_secondary":false,"show_icon_sound_secondary":false,"height":"adapt","position":"outside","layout":"text_last","margin_top":"no-indent","margin_bottom":"no-indent","padding_top":"no-indent","padding_bottom":"no-indent"}},"instagram_collage_zMDBiK":{"type":"instagram-collage","name":"t:sections.instagram-collage.presets.name","settings":{"section_type":"slideshow_2","subheading":"","heading":"The Women Behind The Work","heading_size":"h2","speed_slider_1":500,"speed_slider_2":700,"column_to_show":6,"image_ratio":"square","show_account":false,"name_account":"Visually tell your brand story","link_account":"","show_description":true,"button_label":"Meet Them All","button_link":"https:\/\/www.google.com","button_style":"primary","icon":"none","padding_top":"l","padding_bottom":"no-indent"}},"multicolumn_E86xGC":{"type":"multicolumn","blocks":{"column_PziJkH":{"type":"column","settings":{"image":"shopify:\/\/sh