{{ 'section-sattva-image-with-text.css' | asset_url | stylesheet_tag }}

<div class="sattva-image-with-text section-{{ section.id }}-padding sattva-image-with-text--layout-{{ section.settings.layout }}">
  <div class="sattva-image-with-text__container">
    <div class="sattva-image-with-text__content">
      {% if section.settings.subheading != blank %}
        <p class="sattva-image-with-text__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="sattva-image-with-text__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="sattva-image-with-text__text">
          {{ section.settings.text }}
        </div>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="sattva-image-with-text__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
    <div class="sattva-image-with-text__media">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                  {{ section.settings.image | image_url: width: 800 }} 800w,
                  {{ section.settings.image | image_url: width: 1000 }} 1000w"
          sizes="(min-width: 990px) 50vw, 100vw"
          alt="{{ section.settings.heading | escape }}"
          class="sattva-image-with-text__image"
          loading="lazy"
          width="720"
          height="500"
        >
      {% else %}
        <div class="sattva-image-with-text__placeholder"></div>
      {% endif %}
    </div>
  </div>
</div>

{% style %}
  {% render 'section-padding' %}
{% endstyle %}

{% schema %}
{
  "name": "Sattva Image with Text",
  "class": "section-sattva-image-with-text",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Earth Story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Inspired by the panchatattvas, discarded textiles are slowly joined, embellished, and embroidered into pieces of conscious beauty.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "text-left", "label": "Text left, image right" },
        { "value": "text-right", "label": "Text right, image left" }
      ],
      "default": "text-left"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding top"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "Sattva Image with Text"
    }
  ]
}
{% endschema %}
