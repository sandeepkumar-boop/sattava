{{ 'section-sattva-shop-by-category.css' | asset_url | stylesheet_tag }}

<div class="sattva-shop-by-category section-{{ section.id }}-padding">
  <div class="sattva-shop-by-category__container container">
    <div class="sattva-shop-by-category__header">
      {% if section.settings.heading != blank %}
        <h2 class="sattva-shop-by-category__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="sattva-shop-by-category__header-btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
    <div class="sattva-shop-by-category__slider-wrapper">
      <button type="button" class="sattva-shop-by-category__nav sattva-shop-by-category__nav--prev" aria-label="{{ 'general.pagination.previous' | t }}" data-shop-category-prev>
        {% render 'icon-caret-left' %}
      </button>
      <div class="sattva-shop-by-category__grid" data-shop-category-slider>
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'category' %}
            <div class="sattva-shop-by-category__card{% if block.settings.image == blank %} sattva-shop-by-category__card--no-image{% endif %}" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" class="sattva-shop-by-category__card-link">
                <div class="sattva-shop-by-category__card-media" style="--sattva-card-bg: {{ block.settings.background_color }};">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 660 }}"
                      alt="{{ block.settings.title | escape }}"
                      class="sattva-shop-by-category__card-image"
                      loading="lazy"
                      width="330"
                      height="534"
                    >
                  {% endif %}
                  <div class="sattva-shop-by-category__card-body">
                    {% if block.settings.title != blank %}
                      <h3 class="sattva-shop-by-category__card-title">{{ block.settings.title }}</h3>
                    {% endif %}
                    {% if block.settings.description != blank %}
                      <p class="sattva-shop-by-category__card-desc">{{ block.settings.description }}</p>
                    {% endif %}
                  </div>
                </div>
              </a>
            </div>
        {% endcase %}
      {% endfor %}
      </div>
      <button type="button" class="sattva-shop-by-category__nav sattva-shop-by-category__nav--next" aria-label="{{ 'general.pagination.next' | t }}" data-shop-category-next>
        {% render 'icon-caret-right' %}
      </button>
    </div>
  </div>
</div>

<script src="{{ 'sattva-shop-by-category.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-padding' %}
{% endstyle %}

{% schema %}
{
  "name": "Sattva Shop By Category",
  "class": "section-sattva-shop-by-category",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding top"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color (if no image).",
          "default": "#f5f0eb"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Bags"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "totes, small bags,\nbig bags"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sattva Shop By Category",
      "blocks": [
        { "type": "category", "settings": { "title": "Bags", "description": "totes, small bags,\nbig bags", "background_color": "#e8e0d8" } },
        { "type": "category", "settings": { "title": "Organizers", "description": "jewelry boxes, similar organizers", "background_color": "#d4cfc8" } },
        { "type": "category", "settings": { "title": "Home", "description": "cushion covers, runners", "background_color": "#ebe6e0" } },
        { "type": "category", "settings": { "title": "Gifting", "description": "combined/bundled product images styled as gift sets", "background_color": "#e2ddd6" } }
      ]
    }
  ]
}
{% endschema %}
