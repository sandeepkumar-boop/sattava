{{ 'section-sattva-facts-figures.css' | asset_url | stylesheet_tag }}

<div class="sattva-facts-figures section-{{ section.id }}-padding">
  <div class="sattva-facts-figures__container container">
    <div class="sattva-facts-figures__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'stat' %}
            <div class="sattva-facts-figures__item" {{ block.shopify_attributes }}>
              <span class="sattva-facts-figures__number">{{ block.settings.number }}</span>
              <span class="sattva-facts-figures__label">{{ block.settings.label }}</span>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</div>

{% style %}
  {% render 'section-padding' %}
{% endstyle %}

{% schema %}
{
  "name": "Sattva Facts & Figures",
  "class": "section-sattva-facts-figures",
  "settings": [
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding top"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "+3200"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Products Handcrafted"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sattva Facts & Figures",
      "blocks": [
        { "type": "stat", "settings": { "number": "+3200", "label": "Products Handcrafted" } },
        { "type": "stat", "settings": { "number": "+450", "label": "Artisans Trained" } },
        { "type": "stat", "settings": { "number": "2.8 T", "label": "Textiles Upcycled" } },
        { "type": "stat", "settings": { "number": "13", "label": "Neighborhood Reached" } }
      ]
    }
  ]
}
{% endschema %}
