<section class="elements-of-craft">
  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h2 class="craft-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="craft-grid">

      {% for block in section.blocks %}

      <div class="craft-card">

        <div class="craft-image">
          <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="">
        

          <!-- Ellipse Hotspot -->
          <div 
            class="craft-hotspot"
            style="top:{{ block.settings.top }}%; left:{{ block.settings.left }}%;"
          >
            <span class="ellipse"></span>

            <div class="craft-tooltip">
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.text }}</p>
            </div>

          </div>

        </div>

      </div>

      {% endfor %}

    </div>
  </div>
</section>


<style>

.elements-of-craft{
  padding:60px 0;
}

.craft-heading{
  font-size:40px;
  margin-bottom:30px;
}

.craft-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.craft-card:nth-child(3) {
  grid-row: span 2;
}

.craft-card{
  position:relative;
  border-radius:10px;
  overflow:hidden;
}

.craft-image{
  position:relative;
}

.craft-image img{
  width:100%;
  display:block;
  border-radius:10px;
}

/* HOTSPOT POSITION */
.craft-hotspot{
  position:absolute;
  transform:translate(-50%, -50%);
  cursor:pointer;
}

/* ELLIPSE */
.ellipse{
  width:44px;
  height:44px;
  border-radius:50%;
  background:rgba(255,255,255,0.4);
  display:flex;
  align-items:center;
  justify-content:center;
  position:relative;
}

.ellipse::after{
  content:'';
  width:12px;
  height:12px;
  background:#fff;
  border-radius:50%;
}

/* Pulse animation */
.ellipse::before{
  content:'';
  position:absolute;
  width:44px;
  height:44px;
  border-radius:50%;
  border:2px solid #fff;
  animation:pulse 2s infinite;
}

@keyframes pulse{
  0%{transform:scale(1); opacity:1;}
  100%{transform:scale(1.8); opacity:0;}
}

/* Tooltip */
.craft-tooltip{
  position:absolute;
  top:60px;
  left:0;
  width:260px;
  background:#fff;
  padding:18px;
  border-radius:8px;
  box-shadow:0 10px 30px rgba(0,0,0,0.15);
  opacity:0;
  transform:translateY(10px);
  transition:all .3s ease;
  pointer-events:none;
}

.craft-tooltip h4{
  margin-bottom:8px;
  font-size:18px;
}

.craft-tooltip p{
  font-size:14px;
  line-height:1.5;
}

/* SHOW TOOLTIP */
.craft-hotspot:hover .craft-tooltip{
  opacity:1;
  transform:translateY(0);
}

/* TABLET */
@media(max-width:990px){

  .craft-grid{
    grid-template-columns:repeat(2,1fr);
  }

}

/* MOBILE */
@media(max-width:600px){

  .craft-heading{
    font-size:28px;
  }

  .craft-tooltip{
    width:200px;
  }

}

.craft-card{
  position: relative;
  height: 100%;
}

.craft-image{
  position: relative;
  height: 100%;
}

.craft-image img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

</style>


{% schema %}
{
  "name": "Elements of Craft",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elements of Craft"
    }
  ],
  "blocks": [
    {
      "type": "craft",
      "name": "Craft Item",
      "settings": [
        {
          "type": "range",
          "id": "top",
          "label": "Ellipse Vertical Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "left",
          "label": "Ellipse Horizontal Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Kantha Stitching"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Short description about the craft technique."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Elements of Craft"
    }
  ]
}
{% endschema %}