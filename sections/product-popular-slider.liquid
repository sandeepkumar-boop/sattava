{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<div class="popular-products section-{{ section.id }}">
  <div class="container">

    {% if section.settings.heading != blank %}
      <div class="popular-products-header">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="swiper product-slider-{{ section.id }}">
      <ul class="swiper-wrapper list-unstyled">

        {%- for product in section.settings.product_list -%}

          {% assign collection_index = forloop.index0 | modulo: 3 | plus: 1 %}

          <li class="swiper-slide">

            {% render 'product-card',
              product_card_product: product,
              media_size: section.settings.image_ratio,
              media_fit: section.settings.image_fit,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_collection: section.settings.show_collection,
              show_desc: section.settings.show_desc,
              section_id: section.id,
              add_id: forloop.index,
              collection_index: collection_index
            %}

          </li>

        {%- endfor -%}

      </ul>

      <!-- Navigation -->
      <div class="slider-nav">
        <button class="slider-prev-{{ section.id }}">‹</button>
        <button class="slider-next-{{ section.id }}">›</button>
      </div>

    </div>

  </div>
</div>


<style>

.product-slider-{{ section.id }}{
  position:relative;
}

.product-slider-{{ section.id }} .swiper-slide{
  height:auto;
}

/* Navigation */

.slider-nav{
  position:absolute;
  top:40%;
  width:100%;
  display:flex;
  justify-content:space-between;
  pointer-events:none;
}

.slider-prev-{{ section.id }},
.slider-next-{{ section.id }}{
  pointer-events:all;
  width:42px;
  height:42px;
  border-radius:50%;
  border:none;
  background:#fff;
  box-shadow:0 4px 10px rgba(0,0,0,0.15);
  cursor:pointer;
  font-size:22px;
  display:flex;
  align-items:center;
  justify-content:center;
}

.slider-prev-{{ section.id }}:hover,
.slider-next-{{ section.id }}:hover{
  background:#000;
  color:#fff;
}

</style>


<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function(){

new Swiper(".product-slider-{{ section.id }}",{

  slidesPerView:4,
  spaceBetween:20,

  navigation:{
    nextEl:".slider-next-{{ section.id }}",
    prevEl:".slider-prev-{{ section.id }}"
  },

  breakpoints:{
    320:{
      slidesPerView:1.2,
      spaceBetween:10
    },
    768:{
      slidesPerView:2.2
    },
    1024:{
      slidesPerView:3
    },
    1200:{
      slidesPerView:4
    }
  }

});

});
</script>


{% schema %}
{
  "name": "Popular Products Slider",
  "tag": "section",
  "class": "popular-products-slider-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular Products"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "portrait"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show secondary image"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_collection",
      "default": false,
      "label": "Show collection"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "Show description"
    }
  ],
  "presets": [
    {
      "name": "Popular Products Slider"
    }
  ]
}
{% endschema %}