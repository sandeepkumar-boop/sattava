{{ 'section-sattva-gifting-cta.css' | asset_url | stylesheet_tag }}

<div class="sattva-gifting-cta section-{{ section.id }}-padding">
  <div class="sattva-gifting-cta__container container">
    <div class="sattva-gifting-cta__content">
      {% if section.settings.heading != blank %}
        <h2 class="sattva-gifting-cta__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="sattva-gifting-cta__text">
          {{ section.settings.text }}
        </div>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="sattva-gifting-cta__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
    <div class="sattva-gifting-cta__media">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                  {{ section.settings.image | image_url: width: 800 }} 800w"
          sizes="(min-width: 990px) 50vw, 100vw"
          alt="{{ section.settings.heading | escape }}"
          class="sattva-gifting-cta__image"
          loading="lazy"
          width="600"
          height="400"
        >
      {% else %}
        <div class="sattva-gifting-cta__placeholder"></div>
      {% endif %}
    </div>
  </div>
</div>

{% style %}
  {% render 'section-padding' %}
{% endstyle %}

{% schema %}
{
  "name": "Sattva Gifting CTA",
  "class": "section-sattva-gifting-cta",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Thoughtful gifts with story stitched in"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Sattva offers thoughtful corporate gifting - from curated hampers to customised pieces designed for teams, clients, and special occasions. Made in small batches and crafted from upcycled textiles by skilled women artisans, each gift carries purpose, meaning, and a story worth sharing.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Gifting"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding top"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "Sattva Gifting CTA"
    }
  ]
}
{% endschema %}
