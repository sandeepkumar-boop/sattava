{{ 'section-sattva-announcement-bar.css' | asset_url | stylesheet_tag }}

<div
  class="sattva-announcement-bar"
  role="region"
  aria-label="{{ 'sections.header.announcement' | t }}"
  style="--sattva-announcement-bg: {{ section.settings.background_color }}; --sattva-announcement-text: {{ section.settings.text_color }};"
>
  <div class="sattva-announcement-bar__inner">
    {%- if section.settings.text != blank -%}
      <p class="sattva-announcement-bar__text">{{ section.settings.text }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Sattva Announcement Bar",
  "class": "section-sattva-announcement",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Message",
      "default": "Midseason Sale: 20% Off — Auto Applied at Checkout — Limited Time Only"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#6B4C2D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Sattva Announcement Bar",
      "settings": {}
    }
  ]
}
{% endschema %}
