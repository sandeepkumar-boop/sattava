{{ 'section-sattva-hero-banner.css' | asset_url | stylesheet_tag }}

<div class="sattva-hero-banner section-{{ section.id }}-padding" style="--sattva-hero-min-height: {{ section.settings.min_height }}px;">
  <div class="sattva-hero-banner__grid sattva-hero-banner__grid--slider" data-hero-slider>
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'slide' %}
          <div class="sattva-hero-banner__panel sattva-hero-banner__slide" {{ block.shopify_attributes }}>
            <div class="sattva-hero-banner__panel-media">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  srcset="{{ block.settings.image | image_url: width: 720 }} 720w,
                          {{ block.settings.image | image_url: width: 960 }} 960w,
                          {{ block.settings.image | image_url: width: 1200 }} 1200w"
                  sizes="(min-width: 990px) 50vw, 100vw"
                  alt="{{ block.settings.heading | escape }}"
                  class="sattva-hero-banner__image"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="720"
                  height="708"
                >
              {% else %}
                <div class="sattva-hero-banner__placeholder"></div>
              {% endif %}
              <div class="sattva-hero-banner__overlay"></div>
            </div>
            <div class="sattva-hero-banner__content">
              {% if block.settings.heading != blank %}
                <h2 class="sattva-hero-banner__heading">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="sattva-hero-banner__button">
                  {{ block.settings.button_label }}
                </a>
              {% elsif block.settings.button_label != blank %}
                <span class="sattva-hero-banner__button">{{ block.settings.button_label }}</span>
              {% endif %}
            </div>
          </div>
      {% endcase %}
    {% endfor %}
  </div>
  {% if section.blocks.size > 1 %}
    <div class="sattva-hero-banner__dots no-js-hidden" aria-hidden="true">
      {% for block in section.blocks %}
        {% if block.type == 'slide' %}
          <button type="button" class="sattva-hero-banner__dot{% if forloop.first %} is-active{% endif %}" data-hero-dot aria-label="{{ 'sections.slideshow.load_slide' | t: number: forloop.index }}">
          </button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>

<script src="{{ 'sattva-hero-banner.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-padding' %}
{% endstyle %}

{% schema %}
{
  "name": "Sattva Hero Banner",
  "class": "section-sattva-hero",
  "settings": [
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 800,
      "step": 20,
      "default": 700,
      "unit": "px",
      "label": "Minimum height (desktop)"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "no-indent",
      "label": "Padding top"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "no-indent",
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Everyday essentials. Thoughtfully reborn."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sattva Hero Banner",
      "settings": {},
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "Everyday essentials. Thoughtfully reborn.",
            "button_label": "Shop Now"
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Stories in Craft. Purpose in Making.",
            "button_label": "Our Story"
          }
        }
      ]
    }
  ]
}
{% endschema %}
