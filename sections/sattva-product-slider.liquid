{{ 'section-sattva-product-slider.css' | asset_url | stylesheet_tag }}

{% if section.settings.collection != blank %}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
{% endif %}

<div class="sattva-product-slider section-{{ section.id }}-padding">
  <div class="sattva-product-slider__container container">
    {% if section.settings.quote != blank %}
      <blockquote class="sattva-product-slider__quote">{{ section.settings.quote }}</blockquote>
    {% endif %}
    <div class="sattva-product-slider__products-wrapper">
      <div class="sattva-product-slider__products" role="list">
        {% if section.settings.collection != blank %}
          {% assign collection = section.settings.collection %}
          {% assign product_count = section.settings.products_to_show | default: 6 %}
          {% for product in collection.products limit: product_count %}
            <div class="sattva-product-slider__item" role="listitem">
              {% render 'product-card',
                product_card_product: product,
                media_size: section.settings.image_ratio,
                show_secondary_image: false,
                section_id: section.id
              %}
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..4) %}
            <div class="sattva-product-slider__item sattva-product-slider__item--placeholder" role="listitem">
              <div class="sattva-product-slider__placeholder-card">
                <div class="sattva-product-slider__placeholder-media"></div>
                <div class="sattva-product-slider__placeholder-info">
                  <span class="sattva-product-slider__placeholder-title">Product {{ i }}</span>
                  <span class="sattva-product-slider__placeholder-price">—</span>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% style %}
  {% render 'section-padding' %}
{% endstyle %}

{% schema %}
{
  "name": "Sattva Product Slider",
  "class": "section-sattva-product-slider",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote / Heading",
      "default": "“Made slowly. Made with intention. Made by hands that matter.”"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Maximum products to show"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding top"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "l",
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "Sattva Product Slider"
    }
  ]
}
{% endschema %}
